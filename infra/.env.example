# =============================================================================
# EduLearn AI — Environment Variables Template
# Copy this file to .env and fill in real values before running.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=ml_prak_user
POSTGRES_PASSWORD=change_me_super_secret
POSTGRES_DB=ml_prak_db
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=change_me_redis_secret
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
SERVER_PORT=8000
ENVIRONMENT=production
LOG_LEVEL=INFO
VERSION=1.0.0

# ---------------------------------------------------------------------------
# Nginx
# ---------------------------------------------------------------------------
NGINX_PORT=80

# ---------------------------------------------------------------------------
# Connection Strings
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://ml_prak_user:change_me_super_secret@db:5432/ml_prak_db
REDIS_URL=redis://:change_me_redis_secret@redis:6379/0

# ---------------------------------------------------------------------------
# ML Model
# ---------------------------------------------------------------------------
MODEL_DIR=/app/models
PREDICTION_THRESHOLD=0.5

# ---------------------------------------------------------------------------
# LLM Provider (OpenAI-compatible — Flaz.id)
# ---------------------------------------------------------------------------
FLAZ_BASE_URL=https://ai.flaz.id/v1
FLAZ_API_KEY=sk-xxx
LLM_MODEL=MiniMax-M2.7-highspeed

# ---------------------------------------------------------------------------
# Authentication (JWT)
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MIN=60
JWT_REFRESH_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# Firecrawl (Web Search Tool)
# ---------------------------------------------------------------------------
FIRECRAWL_API_KEY=fcc_xxx
FIRECRAWL_CACHE_TTL=3600

# ---------------------------------------------------------------------------
# WebSocket
# ---------------------------------------------------------------------------
WS_HEARTBEAT_INTERVAL=20
WS_HEARTBEAT_TIMEOUT=30
WS_MAX_ITERATIONS=5
WS_AUTH_REQUIRED=true
WS_DEBUG_RAW_EVENTS=false
WS_CONNECTION_LIMIT_PER_USER=3
WS_RATE_MSG_PER_MIN=30
WS_RATE_TOOL_PER_CONV=20
WS_RATE_TOKENS_PER_CONV=8000

# ---------------------------------------------------------------------------
# RAG (pgvector)
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5

# ---------------------------------------------------------------------------
# File Upload (Knowledge Ingestion)
# ---------------------------------------------------------------------------
UPLOAD_MAX_FILE_SIZE_MB=20
UPLOAD_ALLOWED_TYPES=pdf,docx,txt,md
UPLOAD_DIR=/app/uploads

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:80,http://localhost:3000,http://localhost:8080

# ---------------------------------------------------------------------------
# Conversation
# ---------------------------------------------------------------------------
REDIS_CONVERSATION_TTL=86400

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
METRICS_ENABLED=false
