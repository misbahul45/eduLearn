# =============================================================================
# EduLearn AI — Environment Variables Template
# Copy this file to .env and fill in real values before running.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=ml_prak_user
POSTGRES_PASSWORD=change_me_super_secret
POSTGRES_DB=ml_prak_db
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=change_me_redis_secret
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
SERVER_PORT=8000
ENVIRONMENT=production
LOG_LEVEL=INFO
VERSION=1.0.0

# ---------------------------------------------------------------------------
# Nginx
# ---------------------------------------------------------------------------
NGINX_PORT=80

# ---------------------------------------------------------------------------
# Connection Strings
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://ml_prak_user:change_me_super_secret@db:5432/ml_prak_db
REDIS_URL=redis://:change_me_redis_secret@redis:6379/0

# ---------------------------------------------------------------------------
# ML Model
# ---------------------------------------------------------------------------
MODEL_DIR=/app/models

# ---------------------------------------------------------------------------
# LLM Provider (OpenAI-compatible — Flaz.id)
# ---------------------------------------------------------------------------
FLAZ_BASE_URL=https://ai.flaz.id/v1
FLAZ_API_KEY=sk-xxx
LLM_MODEL=MiniMax-M2.7-highspeed

# ---------------------------------------------------------------------------
# Authentication (JWT)
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ---------------------------------------------------------------------------
# Firecrawl (Web Search Tool)
# ---------------------------------------------------------------------------
FIRECRAWL_API_KEY=fcc_xxx

# ---------------------------------------------------------------------------
# WebSocket
# ---------------------------------------------------------------------------
WS_HEARTBEAT_INTERVAL=30
WS_HEARTBEAT_TIMEOUT=10
WS_MAX_CONNECTIONS_PER_USER=5

# ---------------------------------------------------------------------------
# RAG (pgvector)
# ---------------------------------------------------------------------------
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_EMBEDDING_DIMENSION=1536

# ---------------------------------------------------------------------------
# File Upload (Knowledge Ingestion)
# ---------------------------------------------------------------------------
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.md
UPLOAD_DESTINATION=/app/uploads

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:80,http://localhost:3000,http://localhost:8080

# ---------------------------------------------------------------------------
# Conversation
# ---------------------------------------------------------------------------
REDIS_CONVERSATION_TTL_SECONDS=3600
